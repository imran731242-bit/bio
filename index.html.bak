<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>RISHU CODEX LONG BIO</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }
        body {
            background: #030712;
            background-image: radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.08) 0%, rgba(0,0,0,0) 80%);
        }
        /* Glassmorphism + premium card styles */
        .premium-card {
            background: rgba(17, 24, 39, 0.6);
            backdrop-filter: blur(12px);
            border-radius: 1.5rem;
            border: 1px solid rgba(255,255,255,0.05);
            transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
            overflow: hidden;
        }
        .premium-card:hover {
            transform: translateY(-3px);
            border-color: rgba(99, 102, 241, 0.3);
            box-shadow: 0 20px 35px -12px rgba(0,0,0,0.5);
        }
        .gradient-border-card {
            position: relative;
            background: linear-gradient(135deg, #111827, #1f2937);
            border-radius: 1.5rem;
        }
        .gradient-border-card::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: 1.5rem;
            padding: 1px;
            background: var(--gradient);
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
        }
        .card-blue { --gradient: linear-gradient(135deg, #6366f1, #8b5cf6); }
        .card-teal { --gradient: linear-gradient(135deg, #10b981, #06b6d4); }
        .card-amber { --gradient: linear-gradient(135deg, #f59e0b, #ef4444); }
        .card-pink { --gradient: linear-gradient(135deg, #ec4899, #8b5cf6); }

        .floating-input {
            position: relative;
            margin-bottom: 1rem;
        }
        .floating-input input, .floating-input textarea {
            background: rgba(15, 23, 42, 0.9);
            border: 1px solid #2d3a5e;
            transition: all 0.2s;
            padding: 0.75rem 1rem 0.75rem 2.5rem;
            width: 100%;
            border-radius: 0.75rem;
            color: #f1f5f9;
        }
        .floating-input i {
            position: absolute;
            left: 0.85rem;
            top: 50%;
            transform: translateY(-50%);
            color: #6b7280;
            font-size: 0.9rem;
            pointer-events: none;
        }
        .floating-input textarea + i {
            top: 1rem;
            transform: none;
        }
        .floating-input input:focus, .floating-input textarea:focus {
            border-color: var(--focus-color, #6366f1);
            box-shadow: 0 0 0 2px rgba(99,102,241,0.2);
            outline: none;
        }
        .btn-primary {
            background: linear-gradient(105deg, #6366f1 0%, #8b5cf6 100%);
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(99,102,241,0.2);
            padding: 0.6rem 1.2rem;
            border-radius: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.3);
        }
        .btn-secondary {
            background: linear-gradient(105deg, #1e293b 0%, #0f172a 100%);
            border: 1px solid #334155;
        }
        .btn-secondary:hover {
            background: #1e293b;
            border-color: var(--hover-color, #6366f1);
        }
        .result-terminal {
            background: #0a0c10;
            border: 1px solid #2d2f3a;
            border-radius: 0.75rem;
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 0.75rem;
            margin-top: 1rem;
        }
        .copy-btn {
            transition: all 0.1s;
        }
        .copy-btn:hover {
            background: #374151;
            color: #fbbf24;
        }
        .loading-spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            display: inline-block;
            animation: spin 0.6s linear infinite;
            margin-right: 6px;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .char-counter {
            font-size: 0.7rem;
            color: #9ca3af;
            margin-top: 0.25rem;
            text-align: right;
        }
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(0,0,0,0.5);
            padding: 0.2rem 0.6rem;
            border-radius: 2rem;
            font-size: 0.7rem;
        }
    </style>
</head>
<body class="text-gray-200 antialiased">

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg">
                <i class="fas fa-dna text-white text-xl"></i>
            </div>
            <div>
                <h1 class="text-2xl md:text-3xl font-bold tracking-tight bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">RISHU CODEX LONG BIO</h1>
                <div class="flex items-center gap-2 mt-1">
                    <span class="text-xs font-mono text-indigo-400 bg-indigo-950/40 px-2 py-0.5 rounded-full">v3.2.1</span>
                    <span class="flex items-center gap-1 text-xs text-gray-400"><span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span></span> All systems operational</span>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-2 text-xs text-gray-400 bg-black/30 px-3 py-1.5 rounded-full border border-white/5">
            <i class="fas fa-shield-alt text-indigo-400"></i>
            <span>Secure channel · TLS 1.3</span>
        </div>
    </div>

    <!-- 2x2 Grid of Four Independent Premium Modules -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        <!-- MODULE 1: GUEST JWT GENERATOR (Blue/Purple) -->
        <div class="gradient-border-card card-blue">
            <div class="premium-card p-6 h-full flex flex-col">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <i class="fas fa-user-circle text-indigo-400 text-xl"></i>
                        <h2 class="text-lg font-semibold">Guest Account Authentication</h2>
                    </div>
                    <div class="status-badge"><i class="fas fa-shield-alt"></i> Ready</div>
                </div>
                <div class="flex-1">
                    <div class="floating-input">
                        <i class="fas fa-user"></i>
                        <input type="text" id="guest_uid" class="w-full" placeholder="Account UID" />
                    </div>
                    <div class="floating-input">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="guest_pwd" class="w-full" placeholder="Password / Passkey" />
                    </div>
                    <button id="gen_guest_btn" class="btn-primary w-full justify-center mt-2"><i class="fas fa-shield-haltered"></i> Generate JWT</button>
                    <div id="guest_result" class="result-terminal p-3 mt-4 hidden"></div>
                </div>
            </div>
        </div>

        <!-- MODULE 2: GUEST BIO UPDATER (Green/Teal) -->
        <div class="gradient-border-card card-teal">
            <div class="premium-card p-6 h-full flex flex-col">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <i class="fas fa-pen-fancy text-teal-400 text-xl"></i>
                        <h2 class="text-lg font-semibold">Guest Account Bio Manager</h2>
                    </div>
                    <div class="status-badge"><i class="fas fa-clock"></i> Ready</div>
                </div>
                <div class="flex-1">
                    <div class="floating-input">
                        <i class="fas fa-jedi"></i>
                        <textarea id="guest_jwt" rows="2" class="w-full" placeholder="JWT Token"></textarea>
                    </div>
                    <div class="floating-input">
                        <i class="fas fa-paragraph"></i>
                        <textarea id="guest_bio" rows="3" class="w-full bio-textarea" placeholder="New Bio Content"></textarea>
                        <div class="char-counter"><span id="guest_bio_chars">0</span> / 500 characters</div>
                    </div>
                    <button id="update_guest_bio_btn" class="btn-primary w-full justify-center mt-2" style="background: linear-gradient(105deg, #10b981, #06b6d4);"><i class="fas fa-cloud-upload-alt"></i> Update Bio</button>
                    <div id="guest_bio_result" class="result-terminal p-3 mt-4 hidden"></div>
                </div>
            </div>
        </div>

        <!-- MODULE 3: ACCESS TOKEN JWT GENERATOR (Orange/Amber) -->
        <div class="gradient-border-card card-amber">
            <div class="premium-card p-6 h-full flex flex-col">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <i class="fas fa-key text-amber-400 text-xl"></i>
                        <h2 class="text-lg font-semibold">Access Token Authentication</h2>
                    </div>
                    <div class="status-badge"><i class="fas fa-shield-alt"></i> Ready</div>
                </div>
                <div class="flex-1">
                    <div class="floating-input">
                        <i class="fas fa-ticket-alt"></i>
                        <input type="text" id="access_token" class="w-full" placeholder="Access Token" />
                    </div>
                    <button id="gen_token_btn" class="btn-primary w-full justify-center mt-2" style="background: linear-gradient(105deg, #f59e0b, #ef4444);"><i class="fas fa-exchange-alt"></i> Generate JWT</button>
                    <div id="token_result" class="result-terminal p-3 mt-4 hidden"></div>
                </div>
            </div>
        </div>

        
        <div class="gradient-border-card card-pink">
            <div class="premium-card p-6 h-full flex flex-col">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <i class="fas fa-edit text-pink-400 text-xl"></i>
                        <h2 class="text-lg font-semibold">Access Token Bio Manager</h2>
                    </div>
                    <div class="status-badge"><i class="fas fa-clock"></i> Ready</div>
                </div>
                <div class="flex-1">
                    <div class="floating-input">
                        <i class="fas fa-jedi"></i>
                        <textarea id="token_jwt" rows="2" class="w-full" placeholder="JWT Token"></textarea>
                    </div>
                    <div class="floating-input">
                        <i class="fas fa-paragraph"></i>
                        <textarea id="token_bio" rows="3" class="w-full bio-textarea" placeholder="New Bio Content"></textarea>
                        <div class="char-counter"><span id="token_bio_chars">0</span> / 500 characters</div>
                    </div>
                    <button id="update_token_bio_btn" class="btn-primary w-full justify-center mt-2" style="background: linear-gradient(105deg, #ec4899, #8b5cf6);"><i class="fas fa-cloud-upload-alt"></i> Update Bio</button>
                    <div id="token_bio_result" class="result-terminal p-3 mt-4 hidden"></div>
                </div>
            </div>
        </div>
    </div>

    
    <div class="mt-12 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-500 border-t border-white/5 pt-6">
        <div class="flex items-center gap-4">
            <span><i class="fas fa-check-circle text-emerald-500"></i> System: <span class="text-gray-300">Operational</span></span>
            <span><i class="fas fa-code-branch"></i> DEVELOPER RISHU GAMING</span>
            <span><i class="fas fa-lock"></i> JOIN MY CHANNEL</span>
        </div>
        <div class="flex gap-4">
            <span>© 2025 RISHU CODER EVERYTHING IS POSSIBLE</span>
        </div>
    </div>
</div>

<script>

    // Preserve all original IDs and backend logic exactly.
    // Add character counters and live preview enhancements without breaking functionality.

    // Helper: loading state for buttons
    function setButtonLoading(btn, isLoading, originalText) {
        if (isLoading) {
            btn.disabled = true;
            btn.style.opacity = '0.7';
            btn.innerHTML = `<span class="loading-spinner"></span> ${originalText}`;
        } else {
            btn.disabled = false;
            btn.style.opacity = '1';
            btn.innerHTML = originalText;
        }
    }

    // Enhanced result display with copy & timestamp
    function showResult(element, text, isError = false) {
        element.style.display = 'block';
        const timestamp = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute:'2-digit', second:'2-digit' });
        const errorClass = isError ? 'text-red-400' : 'text-emerald-400';
        const statusText = isError ? 'FAILED' : 'SUCCESS';
        const header = `<div class="flex justify-between items-center pb-2 border-b border-gray-700 mb-2 text-xs"><span><span class="${errorClass} font-mono">[${statusText}]</span> <span class="text-gray-500">${timestamp}</span></span><button class="copy-result-btn text-gray-400 hover:text-white transition" data-clipboard="${escapeHtml(text)}"><i class="far fa-copy"></i> Copy</button></div>`;
        const content = `<pre class="whitespace-pre-wrap break-all text-gray-300 text-xs font-mono">${escapeHtml(text)}</pre>`;
        element.innerHTML = header + content;
        const copyBtn = element.querySelector('.copy-result-btn');
        if (copyBtn) {
            copyBtn.addEventListener('click', (e) => {
                const textToCopy = copyBtn.getAttribute('data-clipboard');
                navigator.clipboard.writeText(textToCopy);
                const originalIcon = copyBtn.innerHTML;
                copyBtn.innerHTML = '<i class="fas fa-check"></i> Copied!';
                setTimeout(() => { copyBtn.innerHTML = originalIcon; }, 1500);
            });
        }
    }

    function escapeHtml(str) {
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    // Character counters
    function updateCharCount(textareaId, spanId) {
        const textarea = document.getElementById(textareaId);
        const span = document.getElementById(spanId);
        if (textarea && span) {
            span.innerText = textarea.value.length;
            textarea.addEventListener('input', () => { span.innerText = textarea.value.length; });
        }
    }
    updateCharCount('guest_bio', 'guest_bio_chars');
    updateCharCount('token_bio', 'token_bio_chars');


    const genGuestBtn = document.getElementById('gen_guest_btn');
    const originalGuestText = genGuestBtn.innerHTML;

    genGuestBtn.onclick = async () => {
        const uid = document.getElementById('guest_uid').value.trim();
        const pwd = document.getElementById('guest_pwd').value.trim();
        if (!uid || !pwd) return alert('UID and password required');
        const resultDiv = document.getElementById('guest_result');
        setButtonLoading(genGuestBtn, true, originalGuestText);
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = '<div class="flex items-center gap-2 text-indigo-300"><i class="fas fa-circle-notch fa-spin"></i> Authenticating & generating token...</div>';
        try {
            const res = await fetch('/generate_guest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ uid, password: pwd })
            });
            const data = await res.json();
            if (data.success) {
                const output = `✅ JWT GENERATED\n🔑 JWT: ${data.jwt}\n👤 Nickname: ${data.nickname}\n🆔 Account ID: ${data.account_id}\n🌍 Region: ${data.region}`;
                showResult(resultDiv, output, false);
                document.getElementById('guest_jwt').value = data.jwt;
            } else {
                showResult(resultDiv, `❌ Error: ${data.error}`, true);
            }
        } catch(e) { showResult(resultDiv, `❌ Request failed: ${e.message}`, true); }
        finally { setButtonLoading(genGuestBtn, false, originalGuestText); }
    };

    // ---- Guest Bio Update ----
    const updateGuestBioBtn = document.getElementById('update_guest_bio_btn');
    const originalGuestBioText = updateGuestBioBtn.innerHTML;
    updateGuestBioBtn.onclick = async () => {
        const jwt = document.getElementById('guest_jwt').value.trim();
        const bio = document.getElementById('guest_bio').value.trim();
        if (!jwt || !bio) return alert('JWT and bio text required');
        const resultDiv = document.getElementById('guest_bio_result');
        setButtonLoading(updateGuestBioBtn, true, originalGuestBioText);
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = '<div class="flex items-center gap-2 text-cyan-300"><i class="fas fa-circle-notch fa-spin"></i> Updating bio...</div>';
        try {
            const res = await fetch('/update_bio', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ jwt, bio })
            });
            const data = await res.json();
            if (data.success) {
                showResult(resultDiv, `✅ ${data.message}\nEndpoint used: ${data.endpoint}`, false);
            } else {
                showResult(resultDiv, `❌ ${data.message}`, true);
            }
        } catch(e) { showResult(resultDiv, `❌ Request failed: ${e.message}`, true); }
        finally { setButtonLoading(updateGuestBioBtn, false, originalGuestBioText); }
    };

    // ---- Access Token JWT Generation ----
    const genTokenBtn = document.getElementById('gen_token_btn');
    const originalTokenText = genTokenBtn.innerHTML;
    genTokenBtn.onclick = async () => {
        const token = document.getElementById('access_token').value.trim();
        if (!token) return alert('Access token required');
        const resultDiv = document.getElementById('token_result');
        setButtonLoading(genTokenBtn, true, originalTokenText);
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = '<div class="flex items-center gap-2 text-amber-300"><i class="fas fa-circle-notch fa-spin"></i> Fetching openID & generating JWT...</div>';
        try {
            const res = await fetch('/generate_token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ access_token: token })
            });
            const data = await res.json();
            if (data.success) {
                const output = `✅ JWT GENERATED\n🔑 JWT: ${data.jwt}\n👤 Nickname: ${data.nickname}\n🆔 Account ID: ${data.account_id}\n🌍 Region: ${data.region}`;
                showResult(resultDiv, output);
                document.getElementById('token_jwt').value = data.jwt;
            } else {
                showResult(resultDiv, `❌ Error: ${data.error}`, true);
            }
        } catch(e) { showResult(resultDiv, `❌ Request failed: ${e.message}`, true); }
        finally { setButtonLoading(genTokenBtn, false, originalTokenText); }
    };

    
    const updateTokenBioBtn = document.getElementById('update_token_bio_btn');
    const originalTokenBioText = updateTokenBioBtn.innerHTML;
    updateTokenBioBtn.onclick = async () => {
        const jwt = document.getElementById('token_jwt').value.trim();
        const bio = document.getElementById('token_bio').value.trim();
        if (!jwt || !bio) return alert('JWT and bio text required');
        const resultDiv = document.getElementById('token_bio_result');
        setButtonLoading(updateTokenBioBtn, true, originalTokenBioText);
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = '<div class="flex items-center gap-2 text-pink-300"><i class="fas fa-circle-notch fa-spin"></i> Submitting bio update...</div>';
        try {
            const res = await fetch('/update_bio', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ jwt, bio })
            });
            const data = await res.json();
            if (data.success) {
                showResult(resultDiv, `✅ ${data.message}\nEndpoint used: ${data.endpoint}`, false);
            } else {
                showResult(resultDiv, `❌ ${data.message}`, true);
            }
        } catch(e) { showResult(resultDiv, `❌ Request failed: ${e.message}`, true); }
        finally { setButtonLoading(updateTokenBioBtn, false, originalTokenBioText); }
    };
</script>
</body>
</html>